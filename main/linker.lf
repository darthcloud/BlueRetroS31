[mapping:main]
archive: libmain.a
entries:
    main (noflash)
    devcrypto (noflash)
    interface_common (noflash)
    wavepak_vx (noflash)
    xbox_usb (noflash)

[sections:gcov_info]
entries:
    .gcov_info

[scheme:gcov_default]
entries:
    gcov_info -> flash_rodata

[mapping:gcov_info]
archive: *
entries:
    * (gcov_default);
    gcov_info -> flash_rodata KEEP() SURROUND(_gcov_info)
